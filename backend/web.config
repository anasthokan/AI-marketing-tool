<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS site physical path = this backend folder.
  Node still runs under PM2 on 127.0.0.1:5000.
  IIS (ARR + URL Rewrite) publicly exposes it, e.g. http://SERVER:522
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:5000/{R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
