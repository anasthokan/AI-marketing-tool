MONGO_URI=mongodb://127.0.0.1:27017/ai-marketing
PORT=5000
PUPPETEER_HEADLESS=true
SCHEDULE_TZ=Asia/Kolkata

# Instagram uses Edge by default (more reliable on Windows servers than Chrome)
# IG_BROWSER_CHANNEL=msedge
# IG_BROWSER_CHANNEL=chrome
# Optional explicit path if Edge is elsewhere:
# IG_BROWSER_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

# Image source: auto | pollinations | huggingface
# auto = try HF, fall back to free Pollinations (recommended for free accounts)
IMAGE_SOURCE=auto
SKIP_HF_IMAGES=false

# Fine-grained token with permission: "Make calls to Inference Providers"
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional HF image settings (needs billing credits)
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HF_IMAGE_PROVIDER=together

OPENAI_API_KEY=
REPLICATE_API_TOKEN=
